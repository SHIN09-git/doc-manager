NODE_ENV=production
HOST=0.0.0.0
PORT=8787

# Database
STORE_DRIVER=postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Frontend / CORS / cookies
# APP_BASE_URL is accepted as an alias, but APP_URL is kept for older docs.
APP_URL=https://your-domain.example/index.html
APP_BASE_URL=https://your-domain.example/index.html
CORS_ORIGIN=https://your-domain.example
SESSION_SECURE=true
SESSION_SECRET=replace-with-a-random-secret-at-least-32-chars
APP_ENCRYPTION_SECRET=replace-with-another-random-secret-at-least-32-chars

# AI proxy
AI_PROXY_MODE=live
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_REQUEST_TIMEOUT_MS=60000
AI_COST_RATES={"gpt-4.1-mini":{"prompt_per_1k":0.001,"completion_per_1k":0.004}}
DAILY_USER_REQUEST_LIMIT=100
DAILY_ORG_REQUEST_LIMIT=500
# Optional platform fallback key. Organization keys can still be saved in admin.html.
PLATFORM_OPENAI_API_KEY=
# Set true only when production AI calls are expected to use organization keys saved in admin.html.
ALLOW_ORGANIZATION_AI_KEYS=true

# Email. Resend is the simplest first production option.
EMAIL_MODE=webhook
EMAIL_PROVIDER=resend
EMAIL_FROM=Mowen <noreply@your-domain.example>
EMAIL_RESEND_API_KEY=re_xxx
EMAIL_RESEND_ENDPOINT=https://api.resend.com/emails
EMAIL_CALLBACK_TOKEN=replace-with-email-callback-token

# Manual recharge. Use public image URLs for QR codes.
MANUAL_PAYMENT_RECEIVER_NAME=your payment receiver name
MANUAL_PAYMENT_WECHAT_QR_URL=https://your-domain.example/assets/wechat-pay.png
MANUAL_PAYMENT_ALIPAY_QR_URL=https://your-domain.example/assets/alipay.png
MANUAL_PAYMENT_PACKAGES=[{"id":"pro_month","title":"Pro monthly plan","amount_cny":29,"type":"plan","plan":"pro","duration_days":30,"credits":0},{"id":"credits_1000","title":"1000 AI credits","amount_cny":50,"type":"credits","plan":"","duration_days":0,"credits":1000}]

# Online payment can stay disabled while manual recharge is used.
PAYMENT_CHECKOUT_MODE=disabled
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret
PAYMENT_PLAN_PRICE_MAP={"price_pro":"pro","price_team":"team"}
PAYMENT_SUCCESS_URL=https://your-domain.example/index.html#billing-success
PAYMENT_CANCEL_URL=https://your-domain.example/index.html#billing-cancel

# Backup
BACKUP_DIR=/var/backups/mowen
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_KEY=replace-with-a-long-backup-encryption-key
BACKUP_OBJECT_STORAGE_MODE=disabled
BACKUP_OBJECT_STORAGE_ENDPOINT=
BACKUP_OBJECT_STORAGE_BUCKET=
BACKUP_OBJECT_STORAGE_REGION=us-east-1
BACKUP_OBJECT_STORAGE_PREFIX=production
BACKUP_OBJECT_STORAGE_ACCESS_KEY_ID=
BACKUP_OBJECT_STORAGE_SECRET_ACCESS_KEY=
BACKUP_OBJECT_STORAGE_SESSION_TOKEN=
BACKUP_FAILURE_WEBHOOK_URL=
BACKUP_FAILURE_WEBHOOK_TOKEN=

REQUEST_LOGGING=true
MAX_JSON_BODY_BYTES=1048576
MAX_DOCUMENT_CHARS=200000
