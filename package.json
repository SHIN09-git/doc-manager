{
  "name": "mowen-nibi-workbench",
  "version": "0.1.0",
  "description": "本地优先的文本管理、AI 起草与执笔人构建工作台",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=iife --target=es2022 --outfile=build/bundle.js",
    "build:static": "npm run build && node scripts/build-static.mjs",
    "check": "node --check app.js && node --check src/main.js && node --check src/admin/adminPage.js && node --check e2e/serve-static.mjs && node --check e2e/run-e2e.mjs && node --check playwright.config.js && node --check scripts/build-static.mjs && node --check scripts/health-check.mjs && node --check scripts/verify-production.mjs && node --check build/bundle.js && npm run server:check",
    "test": "node --test test/*.test.js && npm run server:test",
    "serve:static": "node e2e/serve-static.mjs",
    "start:api": "node server/src/server.js",
    "server:dev": "node server/src/server.js",
    "server:check": "node server/scripts/check.mjs",
    "server:test": "node --test server/tests/*.test.js",
    "server:backup": "node server/scripts/backup.mjs",
    "server:backup:verify": "node server/scripts/verify-backup.mjs",
    "server:backup:drill": "node server/scripts/drill-backup-restore.mjs",
    "server:postgres:import": "node server/scripts/import-json-to-postgres.mjs",
    "deploy:check": "node scripts/verify-production.mjs",
    "deploy:health": "node scripts/health-check.mjs",
    "test:e2e": "npm run build && node e2e/run-e2e.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.25.12"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pg": "^8.13.1",
    "pptxgenjs": "^4.0.1"
  }
}
