{
  "name": "mowen-nibi-workbench",
  "version": "0.1.0",
  "description": "本地优先的文本管理、AI 起草与执笔人构建工作台",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=iife --target=es2022 --outfile=build/bundle.js",
    "check": "node --check app.js && node --check src/main.js && node --check build/bundle.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.25.12"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pptxgenjs": "^4.0.1"
  }
}
